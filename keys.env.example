# ================================================
# AWS S3 Secure Backup Tool - Example Configuration
# ================================================
# 1. Copy this file to "keys.env"
# 2. Fill in your real values

# === AWS Credentials ===
AWS_ACCESS_KEY_ID=your_access_key_id_here
AWS_SECRET_ACCESS_KEY=your_secret_access_key_here

# === AWS S3 Settings ===
BUCKET_NAME=your-bucket-name-here
REGION=eu-north-1

# === Local Backup Settings ===
# Path to the folder you want to backup
# On Mac: use ~/Documents/... 
# On Windows: use C:\Users\YourName\...
FOLDER_TO_BACKUP=~/Documents/s3-secure-backup

# === Share Link Settings ===
SHARE_EXPIRATION=3600

# === Decrypt Script Settings ===
S3_KEY=backups/YOUR_TIMESTAMP_HERE/your-file-name.jpg
