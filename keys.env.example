# ================================================
# AWS S3 Secure Backup Tool - Example Configuration
# ================================================
# 1. Copy this file to "keys.env"
# 2. Fill in your real values

# ===================== AWS Credentials =====================
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# ===================== S3 Settings =====================
BUCKET_NAME=your-bucket-name
REGION=your-region                    # e.g. eu-north-1, us-east-1

# ===================== Backup Settings =====================
FOLDER_TO_BACKUP=~/path/to/your/folder

# How long presigned URLs remain valid (in seconds)
SHARE_EXPIRATION=3600

# Parallelism & Retry settings (used by both backup and restore)
MAX_WORKERS=5
MAX_RETRIES=3

# ===================== Restore / Decrypt Settings =====================
# === Single file decrypt (uncomment when needed) ===
# S3_KEY=backups/YYYY-MM-DD_HH-MM-SS/yourfile.ext

# === Full folder restore (currently active) ===
RESTORE_TIMESTAMP=YYYY-MM-DD_HH-MM-SS
# MANIFEST_KEY=backups/YYYY-MM-DD_HH-MM-SS/MANIFEST.json   # alternative, higher priority

# Where to save single decrypted files
OUTPUT_DIR=decrypted

# Show per-file progress bars during restore?
# Set to 0 to disable even when MAX_WORKERS is low
SHOW_PER_FILE_PROGRESS=1

# ===================== Notes =====================
# - For backup:         comment out RESTORE_TIMESTAMP and S3_KEY
# - For single decrypt: uncomment S3_KEY and comment RESTORE_TIMESTAMP
# - For full restore:   use RESTORE_TIMESTAMP (recommended)
# - MAX_WORKERS and SHOW_PER_FILE_PROGRESS affect restore behavior
